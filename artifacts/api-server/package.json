{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set NODE_ENV=development && set MONGODB_URI=mongodb://localhost:27017/saloon && set PORT=3001 && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/supertest": "^2.0.16",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "pino-pretty": "^13",
    "supertest": "^6.3.3",
    "thread-stream": "3.1.0",
    "ts-jest": "^29.1.0"
  }
}
